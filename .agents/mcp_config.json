{
  "mcpServers": {
    "supabase-mcp-server": {
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate",
      "command": "node",
      "args": [
        "node_modules/@supabase/mcp-server-supabase/dist/transports/stdio.js",
        "--access-token",
        "sbp_YOUR_TOKEN_HERE"
      ],
      "env": {}
    },
    "mempalace": {
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate",
      "command": "mempalace-mcp",
      "args": [
        "--palace",
        "C:\\Users\\Admin\\OneDrive\\Documents\\MemPalace\\palace"
      ],
      "env": {}
    },
    "shadcn": {
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate",
      "command": "node",
      "args": [
        "node_modules/shadcn/dist/index.js",
        "mcp"
      ],
      "env": {}
    },
    "obsidian": {
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate",
      "command": "node",
      "args": [
        "node_modules/mcp-obsidian/dist/index.js"
      ],
      "env": {
        "OBSIDIAN_API_KEY": "YOUR_API_KEY",
        "OBSIDIAN_HOST": "127.0.0.1",
        "OBSIDIAN_PORT": "27124"
      }
    }
  }
}