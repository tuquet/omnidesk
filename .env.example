# ====================================
# KBM Boilerplate — Environment Variables
# ====================================
# Copy this file to `.env` and fill in the values.
# cp .env.example .env

# Backend API port (Axum server)
VITE_API_PORT=8080

# Tauri dev server port (Vite)
VITE_DEV_PORT=1420

# ─── RBAC ────────────────────────────────────────────────────────────────────
# When "true", sidebar menus and routes are filtered by the user's role.
# When "false" (default), all menus are visible — guest/client/demo mode.
VITE_RBAC_ENABLED=false
