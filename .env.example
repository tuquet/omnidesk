# ====================================
# KBM — Environment Variables
# ====================================
# Copy this file to `.env` and fill in the values.
# cp .env.example .env

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── GitHub OAuth ────────────────────────────────────────────────────────────
# Create an OAuth App at: https://github.com/settings/developers
# Set callback URL to: http://localhost:1420/auth/callback
VITE_GITHUB_CLIENT_ID=

# ─── Ports ───────────────────────────────────────────────────────────────────
# Backend API port (Axum server — desktop companion)
VITE_API_PORT=1421

# Tauri dev server port (Vite)
VITE_DEV_PORT=1420

# Web platform URL (for OAuth redirect from Desktop → Web → Deep Link)
VITE_WEB_URL=http://localhost:1420

# ─── RBAC ────────────────────────────────────────────────────────────────────
# When "true", sidebar menus and routes are filtered by the user's role.
# When "false" (default), all menus are visible — guest/client/demo mode.
VITE_RBAC_ENABLED=false

# ─── Supabase JWT (Desktop Companion) ────────────────────────────────────────
# Used by the Axum server to verify Supabase JWTs.
# Get from: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=83ebc76d5416378b42cd5ff445ce7662b2084d466058ea797c292cbea8745322
