          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateBrowserProfilePayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Browser profile updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BrowserProfile"
                }
              }
