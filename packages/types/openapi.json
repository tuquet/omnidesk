      "post": {
        "tags": [
          "handlers::browser_profiles"
        ],
        "operationId": "launch_profile",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Browser profile ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startup_url",
            "in": "query",
            "description": "Optional URL to open on launch",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
