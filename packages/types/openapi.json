      "get": {
        "tags": [
          "handlers::browser_profiles"
        ],
        "operationId": "get_download_status",
        "responses": {
          "200": {
            "description": "Download status stream"
          }
        }
      }
    },
    "/api/browser-profiles/engine-status": {
      "get": {
        "tags": [
          "handlers::browser_profiles"
        ],
        "operationId": "get_engine_status",
