        "type": "object",
        "description": "Request payload for pushing workflows from the Extension",
        "required": [
          "workflows"
        ],
        "properties": {
          "workflows": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Workflow"
            }
          }
        }
      },
      "Schedule": {
        "type": "object",
        "description": "Schedule: Profile × Workflow on a cron.",
        "required": [
          "id",
          "name",
          "workflow_id",
          "profile_id",
          "cron_expr"
        ],
        "properties": {
          "created_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "cron_expr": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "is_enabled": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "last_run_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "name": {
            "type": "string"
          },
          "next_run_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "profile_id": {
            "type": "string"
