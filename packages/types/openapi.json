  "components": {
    "schemas": {
      "CreateFolderPayload": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "CreateSchedulePayload": {
        "type": "object",
        "required": [
          "name",
          "workflow_id",
          "profile_id",
          "cron_expr"
        ],
        "properties": {
          "cron_expr": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "profile_id": {
            "type": "string"
          },
          "workflow_id": {
            "type": "string"
          }
        }
      },
      "Credential": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "id": {},
          "name": {
            "type": "string"
          },
          "value": {}
        }
      },
      "DrawflowData": {
        "type": "object",
        "properties": {
          "edges": {},
          "nodes": {}
        }
      },
      "DrawflowEdge": {
        "type": "object",
        "required": [
          "source",
          "target"
        ],
        "properties": {
          "id": {},
          "source": {},
          "target": {}
        }
      },
      "DrawflowNode": {
        "type": "object",
        "properties": {
          "data": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/DrawflowNodeData"
              }
            ]
          },
          "id": {},
          "label": {
            "type": [
              "string",
              "null"
            ]
          },
          "type": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "DrawflowNodeData": {
        "type": "object",
        "properties": {
          "parameters": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "$ref": "#/components/schemas/WorkflowParameter"
            }
          },
          "triggers": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "$ref": "#/components/schemas/WorkflowTrigger"
            }
          }
        }
      },
      "Folder": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "createdAt": {
            "type": [
              "string",
              "null"
