    "/api/browser-profiles": {
      "get": {
        "tags": [
          "profiles"
        ],
        "operationId": "list_profiles",
        "responses": {
          "200": {
            "description": "List of browser profiles",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BrowserProfile"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "profiles"
        ],
        "operationId": "create_profile",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBrowserProfilePayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Browser profile created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BrowserProfile"
                }
              }
            }
          }
        }
      }
    },
    "/api/browser-profiles/browser-engine": {
      "delete": {
        "tags": [
          "handlers::browser_profiles"
        ],
        "operationId": "delete_browser_engine",
