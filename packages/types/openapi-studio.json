  "paths": {
    "/api/automa/workflows": {
      "get": {
        "tags": [
          "workflows"
        ],
        "operationId": "list_workflows",
        "parameters": [
          {
            "name": "since",
            "in": "query",
            "description": "ISO timestamp - return only workflows changed after this time",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List all workflows (or changed since timestamp)"
          }
        }
      },
      "post": {
        "tags": [
          "workflows"
        ],
        "operationId": "create_workflow",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkflowPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Workflow created"
          }
        }
      }
    },
    "/api/automa/workflows/runs/{run_id}": {
      "delete": {
        "tags": [
          "workflows"
        ],
        "operationId": "delete_workflow_run",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Run deleted successfully"
          }
        }
      }
    },
    "/api/automa/workflows/runs/{run_id}/logs": {
      "get": {
        "tags": [
          "workflows"
        ],
        "operationId": "get_run_logs",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "description": "Run ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List workflow logs"
          }
        }
      }
    },
    "/api/automa/workflows/sync/export/{id}": {
      "get": {
        "tags": [
          "sync"
        ],
        "summary": "GET /api/automa/workflows/sync/export/:id\nExport a single workflow as downloadable JSON",
        "operationId": "export_workflow",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Workflow ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Workflow JSON exported"
          }
        }
      }
    },
    "/api/automa/workflows/sync/import": {
      "post": {
        "tags": [
          "sync"
        ],
        "summary": "POST /api/automa/workflows/sync/import\nImport a workflow from JSON body",
        "operationId": "import_workflow",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkflowPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Workflow imported"
          }
        }
      }
    },
    "/api/automa/workflows/sync/local": {
      "post": {
        "tags": [
          "sync"
        ],
        "summary": "POST /api/automa/workflows/sync/local\nReads workflows from a given local folder path and upserts to DB",
        "operationId": "sync_local",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SyncLocalPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Local folder synced successfully"
          }
        }
      }
    },
    "/api/automa/workflows/sync/push": {
      "post": {
        "tags": [
          "sync"
        ],
        "summary": "POST /api/automa/workflows/sync/push\nReceives workflows from the Extension and upserts them into the database + files",
        "operationId": "push_workflows",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PushWorkflowsPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Workflows synced successfully"
          }
        }
      }
    },
    "/api/automa/workflows/sync/status": {
      "get": {
        "tags": [
          "sync"
        ],
        "summary": "GET /api/automa/workflows/sync/status\nReturns current sync status",
        "operationId": "sync_status",
        "responses": {
          "200": {
            "description": "Sync status"
          }
        }
      }
    },
    "/api/automa/workflows/{id}": {
      "get": {
        "tags": [
          "workflows"
        ],
        "operationId": "get_workflow",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Workflow ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Get workflow by ID"
          },
          "404": {
            "description": "Workflow not found"
          }
        }
      },
      "put": {
        "tags": [
          "workflows"
        ],
        "operationId": "update_workflow",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Workflow ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkflowPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Workflow updated"
          },
          "404": {
            "description": "Workflow not found"
          }
        }
      },
      "delete": {
        "tags": [
          "workflows"
        ],
        "operationId": "delete_workflow",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Workflow ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "workspacePath",
            "in": "query",
            "description": "Workspace path",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Workflow deleted"
          },
          "404": {
            "description": "Workflow not found"
          }
        }
      }
    },
    "/api/automa/workflows/{id}/runs": {
      "get": {
        "tags": [
          "workflows"
        ],
        "operationId": "get_workflow_runs",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Workflow ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List workflow runs"
          }
        }
      },
      "delete": {
        "tags": [
          "workflows"
        ],
        "operationId": "delete_all_workflow_runs",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "All runs for workflow deleted successfully"
          }
        }
      }
    },
    "/api/me": {
      "get": {
        "tags": [],
        "operationId": "me",
        "responses": {
