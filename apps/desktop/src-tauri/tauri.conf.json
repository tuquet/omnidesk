{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Kill Bug Machine",
  "version": "0.1.0",
  "identifier": "com.kbm.devtool",
  "build": {
    "beforeDevCommand": "pnpm --filter @kbm/web dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter @kbm/web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kill Bug Machine",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk0MkYzRjlERDEyNjgzNEQKUldSTmd5YlJuVDh2bE9wVi9aSVpOTlFId2h1bnpIZytHZ1YrMlJJR3ZkUXU0dXYyM0xlSjYrbjgK",
      "endpoints": [
        "http://127.0.0.1:1421/updates/latest.json",
        "https://github.com/tuquet/kill-bug-machine/releases/latest/download/latest.json"
      ]
    }
  }
}
