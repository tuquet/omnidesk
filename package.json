{
  "name": "omnidesk",
  "private": true,
  "version": "0.1.0",
  "description": "Tauri + React + Axum monorepo boilerplate",
  "scripts": {
    "dev": "turbo run dev --filter=@omnidesk/web --filter=@omnidesk/app-*",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "typecheck:native": "tsgo --noEmit",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "clean": "turbo run clean",
    "prepare": "husky",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "dev:all": "concurrently -n WEB,DOCS -c blue,green \"pnpm dev\" \"pnpm docs:dev\"",
    "dev:desktop": "pnpm --filter @omnidesk/desktop tauri dev",
    "dev:automa:workflow": "pnpm --filter @omnidesk/automa-workflow tauri dev",
    "dev:automa:profile": "pnpm --filter @omnidesk/automa-profile tauri dev",
    "dev:automa:runtime": "pnpm --filter @omnidesk/automa-runtime tauri dev",
    "dev:automa": "concurrently -n WF,PRF,RT -c blue,magenta,green \"pnpm dev:automa:workflow\" \"pnpm dev:automa:profile\" \"pnpm dev:automa:runtime\""
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.21.0",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@supabase/mcp-server-supabase": "^0.8.2",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^26.0.1",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "concurrently": "^9.0.0",
    "eslint": "^9.21.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.0",
    "shadcn": "^4.12.0",
    "supabase": "^2.105.0",
    "turbo": "^2.3.0",
    "typescript-eslint": "^8.25.0",
    "vite": "^8.1.0",
    "vitepress": "^1.6.4",
    "vue": "^3.5.35"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2"
  }
}
