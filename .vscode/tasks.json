{
  "version": "2.0.0",
  "tasks": [
    // ==========================================
    // === Database Management
    // ==========================================
    {
      "label": "db-reset",
      "type": "shell",
      "command": "pnpm db:reset",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    // ==========================================
    // === Development Servers
    // ==========================================
    {
      "label": "dev-web-vite",
      "type": "shell",
      "command": "node scripts/task-logger.mjs dev-web-vite.log pnpm --filter @omnidesk/web-portal dev",
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": ".", "file": 1, "line": 2, "message": 3 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "dev-docs-vitepress",
      "type": "shell",
      "command": "node scripts/task-logger.mjs dev-docs-vitepress.log pnpm docs:dev",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "dev-omni-studio",
      "type": "shell",
      "command": "node scripts/task-logger.mjs dev-omni-studio.log pnpm --filter @omnidesk/omni-studio tauri dev",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "dev-omni-profile",
      "type": "shell",
      "command": "node scripts/task-logger.mjs dev-omni-profile.log pnpm --filter @omnidesk/omni-profile tauri dev",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "dev-omni-engine",
      "type": "shell",
      "command": "node scripts/task-logger.mjs dev-omni-engine.log pnpm --filter @omnidesk/omni-engine tauri dev",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "dev-all-web-docs",
      "type": "shell",
      "command": "node scripts/task-logger.mjs dev-all-web-docs.log pnpm dev:all",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "dev-all-automa-wf-prf-rt",
      "type": "shell",
      "command": "node scripts/task-logger.mjs dev-all-automa-wf-prf-rt.log pnpm dev:omni",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "dev-automa-extension",
      "type": "shell",
      "command": "node scripts/task-logger.mjs dev-automa-extension.log pnpm --filter @omnidesk/omni-extension dev",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    // ==========================================
    // === Type Checking
    // ==========================================
    {
      "label": "typecheck-native",
      "type": "shell",
      "command": "node scripts/task-logger.mjs typecheck-native-tsgo.log pnpm typecheck:native",
      "group": "build",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "checks"
      }
    },
    {
      "label": "typecheck-standard",
      "type": "shell",
      "command": "node scripts/task-logger.mjs typecheck-standard-tsc.log pnpm turbo typecheck",
      "group": "build",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "checks"
      }
    },

    // ==========================================
    // === Linting & Formatting
    // ==========================================
    {
      "label": "lint-all",
      "type": "shell",
      "command": "node scripts/task-logger.mjs lint-all.log pnpm turbo lint",
      "group": "build",
      "problemMatcher": "$eslint-stylish",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "checks"
      }
    },
    {
      "label": "format-all",
      "type": "shell",
      "command": "node scripts/task-logger.mjs format-all.log pnpm format",
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "format-check",
      "type": "shell",
      "command": "node scripts/task-logger.mjs format-check.log pnpm format:check",
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },

    // ==========================================
    // === Build
    // ==========================================
    {
      "label": "build-all",
      "type": "shell",
      "command": "node scripts/task-logger.mjs build-all-turbo.log pnpm turbo build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "build"
      }
    },
    {
      "label": "build-web-only",
      "type": "shell",
      "command": "node scripts/task-logger.mjs build-web-only.log pnpm --filter @omnidesk/web-portal build",
      "group": "build",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "build"
      }
    },
    {
      "label": "build-all-tauri-apps",
      "type": "shell",
      "command": "node scripts/task-logger.mjs build-all-tauri-apps.log pnpm --filter \"@omnidesk/omni-*\" tauri build",
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "build"
      }
    },

    // ==========================================
    // === Testing
    // ==========================================
    {
      "label": "test-all",
      "type": "shell",
      "command": "node scripts/task-logger.mjs test-all.log pnpm turbo test",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "test"
      }
    },

    // ==========================================
    // === Utilities
    // ==========================================
    {
      "label": "install-dependencies",
      "type": "shell",
      "command": "node scripts/task-logger.mjs install-dependencies.log pnpm install",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "clean-all",
      "type": "shell",
      "command": "node scripts/task-logger.mjs clean-all.log pnpm clean",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "scan-data-testid",
      "type": "shell",
      "command": "node scripts/task-logger.mjs scan-testids.log node scripts/scan-testids.mjs",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },

    // ==========================================
    // === Rust (Tauri Backend)
    // ==========================================
    {
      "label": "rust-check-all",
      "type": "shell",
      "command": "node scripts/task-logger.mjs rust-check-all.log cargo check",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$rustc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "rust"
      }
    },
    {
      "label": "rust-check-runtime",
      "type": "shell",
      "command": "node scripts/task-logger.mjs rust-check-runtime.log cargo check",
      "options": {
        "cwd": "${workspaceFolder}/apps/omni-engine/src-tauri"
      },
      "problemMatcher": "$rustc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "rust"
      }
    },
    {
      "label": "rust-check-workflow",
      "type": "shell",
      "command": "node scripts/task-logger.mjs rust-check-workflow.log cargo check",
      "options": {
        "cwd": "${workspaceFolder}/apps/omni-studio/src-tauri"
      },
      "problemMatcher": "$rustc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "rust"
      }
    },
    {
      "label": "rust-check-profile",
      "type": "shell",
      "command": "node scripts/task-logger.mjs rust-check-profile.log cargo check",
      "options": {
        "cwd": "${workspaceFolder}/apps/omni-profile/src-tauri"
      },
      "problemMatcher": "$rustc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "rust"
      }
    },

    // ==========================================
    // === Git & Deploy
    // ==========================================
    {
      "label": "git-push",
      "type": "shell",
      "command": "node scripts/task-logger.mjs git-push.log git push origin main",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "deploy-trigger-github-release",
      "type": "shell",
      "command": "node scripts/task-logger.mjs deploy-trigger-github-release.log git tag ${input:releaseVersion} && git push origin ${input:releaseVersion}",
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "deploy"
      }
    }
  ],
  "inputs": [
    {
      "id": "releaseVersion",
      "type": "promptString",
      "description": "Nhập phiên bản tag để trigger Release (VD: v0.1.1)",
      "default": "v0.1.1"
    }
  ]
}
