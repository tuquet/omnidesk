{
  "version": "2.0.0",
  "tasks": [
    // ==========================================
    // === Development Servers
    // ==========================================
    {
      "label": "🌐 Dev: Web (Vite)",
      "type": "shell",
      "command": "node scripts/task-logger.mjs dev-web-vite.log \"pnpm --filter @omnidesk/web-portal dev\"",
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": ".", "file": 1, "line": 2, "message": 3 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "📚 Dev: Docs (VitePress)",
      "type": "shell",
      "command": "node scripts/task-logger.mjs dev-docs-vitepress.log \"pnpm docs:dev\"",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "🖥️ Dev: Omni Studio",
      "type": "shell",
      "command": "node scripts/task-logger.mjs dev-omni-studio.log \"pnpm --filter @omnidesk/omni-studio tauri dev\"",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "🖥️ Dev: Omni Profile",
      "type": "shell",
      "command": "node scripts/task-logger.mjs dev-omni-profile.log \"pnpm --filter @omnidesk/omni-profile tauri dev\"",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "🖥️ Dev: Omni Engine",
      "type": "shell",
      "command": "node scripts/task-logger.mjs dev-omni-engine.log \"pnpm --filter @omnidesk/omni-engine tauri dev\"",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "🚀 Dev: All (Web + Docs)",
      "type": "shell",
      "command": "node scripts/task-logger.mjs dev-all-web-docs.log \"pnpm dev:all\"",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "🚀 Dev: All Automa (WF + PRF + RT)",
      "type": "shell",
      "command": "node scripts/task-logger.mjs dev-all-automa-wf-prf-rt.log \"pnpm dev:omni\"",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "🖥️ Dev: Automa Extension",
      "type": "shell",
      "command": "node scripts/task-logger.mjs dev-automa-extension.log \"pnpm --filter @omnidesk/omni-extension dev\"",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    // ==========================================
    // === Type Checking
    // ==========================================
    {
      "label": "⚡ TypeCheck: Native (tsgo)",
      "type": "shell",
      "command": "node scripts/task-logger.mjs typecheck-native-tsgo.log \"pnpm typecheck:native\"",
      "group": "build",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "checks"
      }
    },
    {
      "label": "🔍 TypeCheck: Standard (tsc)",
      "type": "shell",
      "command": "node scripts/task-logger.mjs typecheck-standard-tsc.log \"pnpm turbo typecheck\"",
      "group": "build",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "checks"
      }
    },

    // ==========================================
    // === Linting & Formatting
    // ==========================================
    {
      "label": "🧹 Lint: All",
      "type": "shell",
      "command": "node scripts/task-logger.mjs lint-all.log \"pnpm turbo lint\"",
      "group": "build",
      "problemMatcher": "$eslint-stylish",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "checks"
      }
    },
    {
      "label": "✨ Format: All",
      "type": "shell",
      "command": "node scripts/task-logger.mjs format-all.log \"pnpm format\"",
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "📋 Format: Check",
      "type": "shell",
      "command": "node scripts/task-logger.mjs format-check.log \"pnpm format:check\"",
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },

    // ==========================================
    // === Build
    // ==========================================
    {
      "label": "📦 Build: All (Turbo)",
      "type": "shell",
      "command": "node scripts/task-logger.mjs build-all-turbo.log \"pnpm turbo build\"",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "build"
      }
    },
    {
      "label": "📦 Build: Web Only",
      "type": "shell",
      "command": "node scripts/task-logger.mjs build-web-only.log \"pnpm --filter @omnidesk/web-portal build\"",
      "group": "build",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "build"
      }
    },
    {
      "label": "📦 Build: All Tauri Apps",
      "type": "shell",
      "command": "node scripts/task-logger.mjs build-all-tauri-apps.log \"pnpm --filter \\\"@omnidesk/omni-*\\\" tauri build\"",
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "build"
      }
    },

    // ==========================================
    // === Testing
    // ==========================================
    {
      "label": "🧪 Test: All",
      "type": "shell",
      "command": "node scripts/task-logger.mjs test-all.log \"pnpm turbo test\"",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "test"
      }
    },

    // ==========================================
    // === Utilities
    // ==========================================
    {
      "label": "📥 Install: Dependencies",
      "type": "shell",
      "command": "node scripts/task-logger.mjs install-dependencies.log \"pnpm install\"",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "🗑️ Clean: All",
      "type": "shell",
      "command": "node scripts/task-logger.mjs clean-all.log \"pnpm clean\"",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },

    // ==========================================
    // === Rust (Tauri Backend)
    // ==========================================
    {
      "label": "🦀 Rust: Check All",
      "type": "shell",
      "command": "node scripts/task-logger.mjs rust-check-all.log \"cargo check\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$rustc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "rust"
      }
    },
    {
      "label": "🦀 Rust: Check Runtime",
      "type": "shell",
      "command": "node scripts/task-logger.mjs rust-check-runtime.log \"cargo check\"",
      "options": {
        "cwd": "${workspaceFolder}/apps/omni-engine/src-tauri"
      },
      "problemMatcher": "$rustc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "rust"
      }
    },
    {
      "label": "🦀 Rust: Check Workflow",
      "type": "shell",
      "command": "node scripts/task-logger.mjs rust-check-workflow.log \"cargo check\"",
      "options": {
        "cwd": "${workspaceFolder}/apps/omni-studio/src-tauri"
      },
      "problemMatcher": "$rustc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "rust"
      }
    },
    {
      "label": "🦀 Rust: Check Profile",
      "type": "shell",
      "command": "node scripts/task-logger.mjs rust-check-profile.log \"cargo check\"",
      "options": {
        "cwd": "${workspaceFolder}/apps/omni-profile/src-tauri"
      },
      "problemMatcher": "$rustc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "rust"
      }
    },

    // ==========================================
    // === Git & Deploy
    // ==========================================
    {
      "label": "📤 Git: Push",
      "type": "shell",
      "command": "node scripts/task-logger.mjs git-push.log \"git push origin main\"",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "🚀 Deploy: Trigger GitHub Release",
      "type": "shell",
      "command": "node scripts/task-logger.mjs deploy-trigger-github-release.log \"git tag ${input:releaseVersion} && git push origin ${input:releaseVersion}\"",
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "deploy"
      }
    }
  ],
  "inputs": [
    {
      "id": "releaseVersion",
      "type": "promptString",
      "description": "Nhập phiên bản tag để trigger Release (VD: v0.1.1)",
      "default": "v0.1.1"
    }
  ]
}
