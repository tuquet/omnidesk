{
  "extends": "../../packages/config/tsconfig/react.json",
  "compilerOptions": {
    "allowJs": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["./src/*"],
      "@omnidesk/auth": ["../../packages/auth/src", "../../packages/auth/src/index.ts"],
      "@omnidesk/auth/*": ["../../packages/auth/src/*"],
      "@omnidesk/core": ["../../packages/core/src", "../../packages/core/src/index.ts"],
      "@omnidesk/core/*": ["../../packages/core/src/*"],
      "@omnidesk/app-launcher": ["../../apps/launcher/src", "../../apps/launcher/src/index.ts"],
      "@omnidesk/app-launcher/*": ["../../apps/launcher/src/*"],
      "@omnidesk/ui/*": ["../../packages/ui/src/*"],
      "@omnidesk/ui": ["../../packages/ui/src"]
    }
  },
  "include": [
    "src",
    "vite.config.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
    "eslint.config.js",
    "openapi-ts.config.ts",
    "scripts/generate-app.mjs"
  ]
}
