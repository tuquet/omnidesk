{
  "openapi": "3.1.0",
  "info": {
    "title": "omnidesk",
    "description": "Premium B2B Enterprise Platform with App Marketplace",
    "contact": {
      "name": "OmniDesk Team"
    },
    "license": {
      "name": ""
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/apps": {
      "get": {
        "tags": [
          "handlers::apps"
        ],
        "summary": "Fetch all apps from the marketplace (Cloud Supabase)",
        "operationId": "get_apps",
        "responses": {
          "200": {
            "description": "Returns all marketplace apps"
          }
        }
      }
    },
    "/api/apps/install/{id}": {
      "post": {
        "tags": [
          "handlers::apps"
        ],
        "summary": "Install an app for the current user",
        "operationId": "install_app",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "App ID to install",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "App installed successfully"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      },
      "delete": {
        "tags": [
          "handlers::apps"
        ],
        "summary": "Uninstall an app for the current user",
        "operationId": "uninstall_app",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "App ID to uninstall",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "App uninstalled successfully"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/apps/installed": {
      "get": {
        "tags": [
          "handlers::apps"
        ],
        "summary": "Fetch installed apps for the current user",
        "operationId": "get_installed_apps",
        "responses": {
          "200": {
            "description": "Returns list of installed app IDs"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/apps/installed-details": {
      "get": {
        "tags": [
          "handlers::apps"
        ],
        "summary": "Fetch installed apps for the current user with versions",
        "operationId": "get_installed_details",
        "responses": {
          "200": {
            "description": "Returns list of installed apps with versions"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/me": {
      "get": {
        "tags": [],
        "summary": "Protected: Returns the authenticated user's info from their JWT claims.",
        "operationId": "me",
        "responses": {
          "200": {
            "description": "Returns authenticated user info"
          },
          "401": {
            "description": "Unauthorized — missing or invalid token"
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [],
        "operationId": "health_check",
        "responses": {
          "200": {
            "description": "Returns health status of the API"
          }
        }
      }
    },
    "/ping": {
      "get": {
        "tags": [],
        "operationId": "ping",
        "responses": {
          "200": {
            "description": "Returns pong"
          }
        }
      }
    },
    "/updates/latest.json": {
      "get": {
        "tags": [],
        "operationId": "latest_update",
        "responses": {
          "200": {
            "description": "Returns latest update info for dev"
          }
        }
      }
    }
  },
  "components": {},
  "tags": [
    {
      "name": "health",
      "description": "Health check endpoints"
    },
    {
      "name": "auth",
      "description": "Authenticated endpoints"
    },
    {
      "name": "apps",
      "description": "Marketplace apps endpoints"
    }
  ]
}